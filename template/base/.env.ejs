# Server Configuration
PORT=8080
NODE_ENV=development

# Security
CORS_ORIGIN=http://localhost:3000
<% if (useJWT) { -%>
JWT_SECRET=<%= Array.from({length: 64}, () => Math.floor(Math.random() * 16).toString(16)).join('') %>
JWT_EXPIRES_IN=1d
<% } -%>
<% if (useUsersDomain) { -%>
BCRYPT_SALT_ROUNDS=10
<% } -%>

<% if (useDB) { -%>
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=<%= projectName %>_db
DB_PORT=3306
<% } -%>